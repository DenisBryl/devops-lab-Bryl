3f\u0438\u0441\u0430\u043d\u0438\u0435: \u0414\u0438\u043f\u043b\u043e\u043c\u043d\u044b\u0439 \u043f\u0440\u043e\u0435\u043a\u0442 \u2014 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430 \u0434\u043b\u044f \u0437\u0430\u043f\u0438\u0441\u0438 \u043a \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u0430\u043c \u0441 \u0443\u0434\u043e\u0431\u043d\u044b\u043c UX \u0438 \u043f\u043e\u043d\u044f\u0442\u043d\u044b\u043c \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u0441\u043a\u0438\u043c \u043f\u0443\u0442\u0451\u043c.</p> <p>\u0427\u0442\u043e \u0441\u0434\u0435\u043b\u0430\u043d\u043e:</p> <ul> <li>\u041f\u0440\u043e\u0432\u0451\u043b \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u0440\u044b\u043d\u043a\u0430 \u0438 \u043f\u043e\u0442\u0440\u0435\u0431\u043d\u043e\u0441\u0442\u0435\u0439 \u0446\u0435\u043b\u0435\u0432\u043e\u0439 \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u0438</li> <li>\u0421\u043f\u0440\u043e\u0435\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043b UX \u0438 \u0441\u043e\u0437\u0434\u0430\u043b \u0438\u043d\u0442\u0435\u0440\u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439 \u043f\u0440\u043e\u0442\u043e\u0442\u0438\u043f \u0432 Figma</li> <li>\u0421\u0430\u043c\u043e\u0441\u0442\u043e\u044f\u0442\u0435\u043b\u044c\u043d\u043e \u0440\u0435\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043b \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u043e\u0442 \u0438\u0434\u0435\u0438 \u0434\u043e \u0437\u0430\u0449\u0438\u0442\u044b \u043d\u0430 \u00ab\u043e\u0442\u043b\u0438\u0447\u043d\u043e\u00bb</li> <li>\u0421\u043e\u0432\u043c\u0435\u0441\u0442\u0438\u043b \u0440\u043e\u043b\u0438 \u043f\u0440\u043e\u0434\u0430\u043a\u0442-\u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440\u0430, \u0434\u0438\u0437\u0430\u0439\u043d\u0435\u0440\u0430 \u0438 data scientist</li> </ul> <p>\u0422\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438: Figma, Python, SQL</p>"},{"location":"projects/#tutogpt-","title":"\ud83e\udd16 TutoGPT \u2014 \u0418\u0418-\u0440\u0435\u043f\u0435\u0442\u0438\u0442\u043e\u0440","text":"<p>\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435: \u0418\u0418-\u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043d\u0442 \u0434\u043b\u044f \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f, \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043d\u043d\u044b\u0439 \u0432 \u0440\u0430\u043c\u043a\u0430\u0445 \u043a\u043e\u043d\u043a\u0443\u0440\u0441\u0430 \u043f\u043e \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u043e\u043c\u0443 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0443.</p> <p>\u0427\u0442\u043e \u0441\u0434\u0435\u043b\u0430\u043d\u043e:</p> <ul> <li>\u0420\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043b \u043a\u043e\u043d\u0446\u0435\u043f\u0446\u0438\u044e \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430 \u0438 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044e \u0441\u0442\u0430\u0434\u0438\u0438 pre-seed</li> <li>\u0424\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043b \u0431\u044d\u043a\u043b\u043e\u0433, \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u043b \u0433\u0438\u043f\u043e\u0442\u0435\u0437\u0430\u043c\u0438, \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0438\u043b \u0446\u0435\u043d\u043d\u043e\u0441\u0442\u043d\u043e\u0435 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0435</li> <li>\u0420\u0443\u043a\u043e\u0432\u043e\u0434\u0438\u043b \u043a\u043e\u043c\u0430\u043d\u0434\u043e\u0439 \u0438 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u043b \u043f\u0440\u043e\u0435\u043a\u0442 \u0436\u044e\u0440\u0438</li> </ul> <p>\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442: \ud83c\udfc6 \u041f\u043e\u0431\u0435\u0434\u0438\u0442\u0435\u043b\u044c \u043a\u043e\u043d\u043a\u0443\u0440\u0441\u0430 \u043f\u043e \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u043e\u043c\u0443 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0443</p> <p>\u0422\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438: Python, LLM, Figma</p>"},{"location":"projects/#bioquiz-","title":"\ud83d\udcda BioQuiz \u2014 \u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u0432\u0435\u0431-\u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435","text":"<p>\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435: \u041a\u043e\u043c\u0430\u043d\u0434\u043d\u044b\u0439 \u043f\u0440\u043e\u0435\u043a\u0442 \u2014 \u0432\u0435\u0431-\u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u0434\u043b\u044f \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f \u0447\u0435\u0440\u0435\u0437 \u043a\u0432\u0438\u0437\u044b.</p> <p>\u0427\u0442\u043e \u0441\u0434\u0435\u043b\u0430\u043d\u043e:</p> <ul> <li>\u0421\u0444\u043e\u0440\u043c\u0443\u043b\u0438\u0440\u043e\u0432\u0430\u043b \u0432\u0438\u0434\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430 \u0438 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0438 \u0432\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439</li> <li>\u0420\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043b \u0438 \u043f\u0440\u043e\u0442\u0435\u0441\u0442\u0438\u0440\u043e\u0432\u0430\u043b \u0441\u0435\u0440\u0432\u0435\u0440\u043d\u0443\u044e \u0447\u0430\u0441\u0442\u044c (backend)</li> <li>\u0420\u0430\u0431\u043e\u0442\u0430\u043b \u0432 \u043a\u043e\u043c\u0430\u043d\u0434\u0435, \u0441\u043e\u0432\u043c\u0435\u0449\u0430\u044f \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u043e\u0432\u044b\u0435 \u0438 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438</li> </ul> <p>\u0422\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438: Python, SQL, Git</p>"},{"location":"projects/#tinder-for-fights-","title":"\ud83e\udd4a Tinder For Fights \u2014 \u043f\u043e\u0438\u0441\u043a \u0441\u043f\u0430\u0440\u0440\u0438\u043d\u0433-\u043f\u0430\u0440\u0442\u043d\u0451\u0440\u043e\u0432 \u043f\u043e \u0435\u0434\u0438\u043d\u043e\u0431\u043e\u0440\u0441\u0442\u0432\u0430\u043c","text":"<p>\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435: \u041c\u043e\u0431\u0438\u043b\u044c\u043d\u043e\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u0434\u043b\u044f \u043f\u043e\u0438\u0441\u043a\u0430 \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u043e\u0432 \u043f\u043e \u0442\u0430\u0439\u0441\u043a\u043e\u043c\u0443 \u0431\u043e\u043a\u0441\u0443 \u0438 \u0434\u0440\u0443\u0433\u0438\u043c \u0435\u0434\u0438\u043d\u043e\u0431\u043e\u0440\u0441\u0442\u0432\u0430\u043c.</p> <p>\u0427\u0442\u043e \u0441\u0434\u0435\u043b\u0430\u043d\u043e:</p> <ul> <li>\u041e\u043f\u0440\u0435\u0434\u0435\u043b\u0438\u043b \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b \u0438 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f</li> <li>\u0420\u0435\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043b \u0441\u0435\u0440\u0432\u0435\u0440\u043d\u0443\u044e \u043b\u043e\u0433\u0438\u043a\u0443 \u043d\u0430 Python</li> <li>\u0417\u0430\u043d\u0438\u043c\u0430\u043b\u0441\u044f \u043f\u0440\u0438\u043e\u0440\u0438\u0442\u0438\u0437\u0430\u0446\u0438\u0435\u0439 \u0437\u0430\u0434\u0430\u0447, \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0446\u0438\u0435\u0439 \u043a\u043e\u043c\u0430\u043d\u0434\u044b \u0438 \u043f\u0440\u0435\u0437\u0435\u043d\u0442\u0430\u0446\u0438\u0435\u0439 \u043f\u0440\u043e\u0435\u043a\u0442\u0430</li> </ul> <p>\u0422\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438: Python, Git</p>"}]}